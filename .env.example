    def add_variable(self, variable: EnvironmentVariable) -> None:
        """
        Add an environment variable to the configuration.
        
        Args:
            variable: The EnvironmentVariable instance to add
            
        Raises:
            ValueError: If a variable with the same name already exists
        """
        if variable.name in self._variables:
            raise ValueError(f"Environment variable '{variable.name}' already exists")
        self._variables[variable.name] = variable
    
    def get_variable(self, name: str) -> Optional[EnvironmentVariable]:
        """
        Get an environment variable by name.
        
        Args:
            name: The name of the environment variable
            
        Returns:
            The EnvironmentVariable instance if found, None otherwise
        """
        return self._variables.get(name)
    
    def get_all_variables(self) -> Dict[str, EnvironmentVariable]:
        """
        Get all configured environment variables.
        
        Returns:
            Dictionary of all environment variables
        """
        return self._variables.copy()
    
    def validate_environment(self) -> bool:
        """
        Validate that all required environment variables are set.
        
        Returns:
            True if all required variables are set, False otherwise
        """
        missing_variables: list[str] = []
        
        for variable in self._variables.values():
            if variable.required:
                value = os.getenv(variable.name)
                if value is None or value.strip() == "":
                    missing_variables.append(variable.name)
        
        if missing_variables:
            logger.error(f"Missing required environment variables: {', '.join(missing_variables)}")
            return False
        
        return True
    
    def generate_env_file(self, filepath: str = ".env.example") -> None:
        """
        Generate a .env.example file with all configured variables.
        
        Args:
            filepath: Path where the .env.example file will be created
            
        Raises:
            IOError: If unable to write to the specified filepath
        """
        try:
            with open(filepath, 'w', encoding='utf-8') as f:
                f.write("# Environment Variables Configuration\n")
                f.write("# Copy this file to .env and fill in the appropriate values\n")
                f.write("# ============================================================\n\n")
                
                # Group variables by category
                categories: Dict[str, list[EnvironmentVariable]] = {}
                
                for variable in self._variables.values():
                    category = variable.name.split('_')[0] if '_' in variable.name else "GENERAL"
                    if category not in categories:
                        categories[category] = []
                    categories[category].append(variable)
                
                # Write variables grouped by category
                for category in sorted(categories.keys()):
                    f.write(f"# {category} Configuration\n")
                    f.write("# " + "-" * 50 + "\n")
                    
                    for variable in sorted(categories[category], key=lambda v: v.name):
                        # Write description as comment
                        f.write(f"# {variable.description}\n")
                        
                        # Write required/optional indicator
                        if variable.required:
                            f.write("# REQUIRED\n")
                        else:
                            f.write("# OPTIONAL\n")
                        
                        # Write default value if exists
                        if variable.default_value:
                            f.write(f"# Default: {variable.default_value}\n")
                        
                        # Write example value if exists
                        if variable.example_value:
                            f.write(f"# Example: {variable.example_value}\n")
                        
                        # Write the variable with example value
                        example = variable.example_value or variable.default_value or ""
                        f.write(f"{variable.name}={example}\n\n")
                    
                    f.write("\n")
                
                f.write("# End of environment variables configuration\n")
            
            logger.info(f"Successfully generated {filepath}")
            
        except IOError as e:
            logger.error(f"Failed to generate {filepath}: {str(e)}")
            raise
    
    def load_from_file(self, filepath: str = ".env") -> bool:
        """
        Load environment variables from a .env file.
        
        Args:
            filepath: Path to the .env file
            
        Returns:
            True if file was loaded successfully, False otherwise
        """
        try:
            env_path = Path(filepath)
            if not env_path.exists():
                logger.warning(f"Environment file {filepath} not found")
                return False
            
            with open(env_path, 'r', encoding='utf-8') as f:
                for line in f:
                    line = line.strip()
                    if line and not line.startswith('#') and '=' in line:
                        key, value = line.split('=', 1)
                        key = key.strip()
                        value = value.strip()
                        os.environ[key] = value
            
            logger.info(f"Successfully loaded environment from {filepath}")
            return True
            
        except IOError as e:
            logger.error(f"Failed to load environment from {filepath}: {str(e)}")
            return False


def main() -> None:
    """
    Main function to generate the .env.example file.
    """
    try:
        config = EnvironmentConfig()
        
        # Generate the .env.example file
        config.generate_env_file()
        
        # Validate the current environment
        if config.validate_environment():
            logger.info("All required environment variables are set")
        else:
            logger.warning("Some required environment variables are missing")
        
        # Print summary
        variables = config.get_all_variables()
        logger.info(f"Total environment variables configured: {len(variables)}")
        logger.info(f"Required variables: {sum(1 for v in variables.values() if v.required)}")
        logger.info(f"Optional variables: {sum(1 for v in variables.values() if not v.required)}")
        
    except Exception as e:
        logger.error(f"Failed to generate environment configuration: {str(e)}")
        raise


if __name__ == "__main__":
    main()